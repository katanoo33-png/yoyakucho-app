{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/security-scan.ps1",
            "shell": "powershell",
            "if": "Bash(git push *)",
            "timeout": 30,
            "statusMessage": "セキュリティスキャン中..."
          }
        ]
      }
    ]
  }
}
